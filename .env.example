# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/rag_evals
POSTGRES_DB=rag_evals
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here

# Ollama Configuration (for local LLM)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:1.5b

# OpenAI Configuration (alternative to Ollama for production)
# OPENAI_API_KEY=sk-your-key-here

# API Configuration
API_KEY=your_secret_api_key_here  # Optional: for API authentication

# Application Settings
ENVIRONMENT=production
LOG_LEVEL=INFO
CACHE_TTL_SECONDS=3600

# CORS Settings (comma-separated domains)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Embedding Model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Retrieval Settings
DEFAULT_TOP_K=5
SIMILARITY_THRESHOLD=0.45
